# run this to add the file to autorun on each cmd launch: reg add "HKCU\Software\Microsoft\Command Processor" /v AutoRun /d "doskey /macrofile=\"C:\PATH\TO\YOUR\cmd_aliases.doskey\"" /t REG_SZ /f

clear=cls
ls=dir $*
ll=dir $*
cat=type $*
cp=copy $*
mv=move $*
rm=del $*
grep=findstr $*
which=where $*
man=help $*
pwd=cd
ps=tasklist
kill=taskkill $*
ifconfig=ipconfig $*
env=set
history=doskey /history
touch=type nul > $1
